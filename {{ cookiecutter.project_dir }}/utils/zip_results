def get_metadata():
    """Read/parse the project .ini file containing information inserted during
    project creation."""
    # metadata = configparser.ConfigParser()
    # metadata.read(ini_path)
    with open("pyproject.toml", "rb") as f:
        metadata = tomllib.load(f)
    return metadata


